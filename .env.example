# Flask
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=  # OBRIGATÓRIO — Gerar com: python -c "import secrets; print(secrets.token_hex(32))"

# PostgreSQL
POSTGRES_USER=askly
POSTGRES_PASSWORD=  # OBRIGATÓRIO — Defina uma senha forte
POSTGRES_DB=askly_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Database URL (construída a partir das variáveis acima)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Test Database
TEST_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/askly_test_db

# Security
CORS_ORIGINS=http://localhost:5000  # Separar múltiplas origens com vírgula

# Seed (opcional — se não definir, será gerada uma senha aleatória)
ADMIN_SEED_PASSWORD=
